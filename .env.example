# =============================================================================
# .env.example — copy to .env and fill in your values
# NEVER commit .env to version control
# =============================================================================

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=eu-west-1
AWS_ACCOUNT_ID=123456789012

# ── Snowflake ─────────────────────────────────────────────────────────────────
SNOWFLAKE_ACCOUNT=myorg-myaccount
SNOWFLAKE_USER=svc_data_engineer
SNOWFLAKE_PASSWORD=              # Use RSA key in production
SNOWFLAKE_PRIVATE_KEY_PATH=~/.snowflake/rsa_key.p8
SNOWFLAKE_DATABASE=RESTAURANT_DB
SNOWFLAKE_WAREHOUSE=DATA_ENGINEERING_WH
SNOWFLAKE_ROLE=DATA_ENGINEER

# ── Airflow ───────────────────────────────────────────────────────────────────
AIRFLOW__CORE__FERNET_KEY=        # Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@localhost:5432/airflow
AIRFLOW__WEBSERVER__SECRET_KEY=   # Random string

# ── Iceberg / S3 ──────────────────────────────────────────────────────────────
ICEBERG_WAREHOUSE=s3://restaurant-iceberg-dev/
GLUE_CATALOG_REGION=eu-west-1

# ── Kafka / MSK ───────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=msk-cluster.restaurant.internal:9092

# ── External APIs (stored in Secrets Manager in production) ───────────────────
TOAST_API_KEY=
DOORDASH_API_KEY=
UBEREATS_API_KEY=
SUPPLIER_API_KEY=
PAGERDUTY_INTEGRATION_KEY=
SLACK_WEBHOOK_URL=
